{
  "name": "lynx-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=web",
    "dev:mobile": "turbo dev --filter=mobile",
    "dev:api": "turbo dev --filter=api",
    "start:api": "node apps/api/dist/index.js",
    "start:web": "npm run start --workspace=web"
  },
  "devDependencies": {
    "tsx": "^4.11.0",
    "turbo": "^2.3.0"
  },
  "packageManager": "npm@10.0.0"
}
